ANTHROPIC_API_KEY=your-anthropic-key-here

# Only required when WHISPER_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here

LLM_PROVIDER=claude

# Whisper: "local" (no API key needed) or "openai" (uses OPENAI_API_KEY)
WHISPER_PROVIDER=local
# Local model size: tiny | base | small | medium | large (larger = more accurate, slower)
WHISPER_MODEL=base

# Cost protection: daily AI credit budget per user, by tier. A user's tier lives in
# the DB (default "free"); there is no billing yet, so promote by hand with
#   sqlite3 nutrition.db "UPDATE user SET tier='pro' WHERE username='...'"
TIER_DAILY_CREDITS={"free": 20, "pro": 300}
# What each action costs. Voice is dearer because it pays for transcription *and*
# the LLM analysis that follows.
CREDIT_COSTS={"text": 1, "clarify": 1, "voice": 3}
# App-wide ceiling across all users — the circuit breaker against a runaway bill.
# Set it well above normal daily usage; if it trips, everyone is locked out until
# local midnight, which is the deliberate trade.
GLOBAL_DAILY_CREDITS=500

# Invite code required to register. LEAVE EMPTY ONLY FOR LOCAL DEV — an open signup
# lets anyone create accounts and spend your API budget. The app logs a warning at
# startup while this is unset.
SIGNUP_CODE=

APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:////data/nutrition.db

# Set to true when serving over HTTPS, so session cookies get the Secure flag
COOKIE_SECURE=false

# Admin panel at /admin. Both values must be set for the admin to be created on
# startup; if the account already exists its password is reset to this value.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
