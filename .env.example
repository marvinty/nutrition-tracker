ANTHROPIC_API_KEY=your-anthropic-key-here

# Only required when WHISPER_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here

LLM_PROVIDER=claude

# Whisper: "local" (no API key needed) or "openai" (uses OPENAI_API_KEY)
WHISPER_PROVIDER=local
# Local model size: tiny | base | small | medium | large (larger = more accurate, slower)
WHISPER_MODEL=base

APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:////data/nutrition.db
